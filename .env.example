# Copy to .env and fill in values — never commit .env to git

# ── Snowflake connection (Phase 2) ────────────────────────────────────────────
# Account identifier: <org_name>-<account_name> (e.g. myorg-myaccount)
# Find yours: Admin > Accounts in Snowsight, or run SELECT CURRENT_ACCOUNT()
SNOWFLAKE_ACCOUNT=sensecorporation.snowflakecomputing.com

# Your Snowflake username
SNOWFLAKE_USER=DQ_ACCELERATOR_SVC_USER

# Key-pair authentication
# Option A: Path to your private key file (recommended)
SNOWFLAKE_PRIVATE_KEY_PATH=~/.ssh/generic_snowflake_rsa_key.p8
# Option B: Inline PEM string (for CI/CD, Docker, etc.)
# SNOWFLAKE_PRIVATE_KEY=

# Passphrase if your private key is encrypted (leave blank if not encrypted)
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Snowflake objects (created by snowflake/setup.sql)
SNOWFLAKE_WAREHOUSE=DQ_WH
SNOWFLAKE_DATABASE=DQ_ACCELERATOR
SNOWFLAKE_SCHEMA=ASSESSMENTS
SNOWFLAKE_ROLE=DQ_APP_ROLE

# ── Snowflake stage configuration ─────────────────────────────────────────────
SNOWFLAKE_PDF_INTERNAL_STAGE=DQ_ACCELERATOR.UNSTRUCTURED.PDF_INTERNAL_STAGE
SNOWFLAKE_PDF_S3_STAGE=DQ_ACCELERATOR.UNSTRUCTURED.PDF_S3_STAGE
SNOWFLAKE_S3_BUCKET=
SNOWFLAKE_S3_PREFIX=dq-docs/

# ── App config ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
