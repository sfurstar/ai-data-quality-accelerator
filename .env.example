# Copy to .env and fill in values — never commit .env to git

# LLM (Phase 1: Claude API for unstructured PDF analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Phase 2: Snowflake credentials (leave blank for Phase 1)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# App config
APP_ENV=development           # development | production
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
